# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── App Settings ───────────────────────────────────────────
APP_NAME=PaySure
APP_ENV=development
DEBUG=True
SECRET_KEY=your_secret_key_here

# ─── JWT Settings ───────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Clerk (Auth) ───────────────────────────────────────────
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# ─── Razorpay (Test Mode) ───────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Email ──────────────────────────────────────────────────
EMAIL_PROVIDER=             # "sendgrid" | "resend" | "" (disables email)
EMAIL_FROM=noreply@paysure.app
SENDGRID_API_KEY=
RESEND_API_KEY=
FRONTEND_URL=http://localhost:5173

# ─── Pusher Channels (Real-time Chat) ───────────────────────
# Create a free app at https://pusher.com → Channels
# Free tier: 200k messages/day, 100 concurrent connections
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2          # Asia Pacific. Options: us2, eu, ap1, ap2, ap3, sa1

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
